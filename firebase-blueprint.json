{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "patient"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Patient appointment details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientUid": { "type": "string" },
        "patientName": { "type": "string" },
        "patientPhone": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientUid", "patientName", "patientPhone", "date", "service", "status"]
    },
    "Medicine": {
      "title": "Medicine",
      "description": "Pharmacy medicine inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "price": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "stock", "price", "expiryDate"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "Patient uploaded prescription for pharmacy",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientUid": { "type": "string" },
        "patientName": { "type": "string" },
        "patientPhone": { "type": "string" },
        "imageData": { "type": "string", "description": "Base64 encoded image data" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "ready", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientUid", "patientName", "patientPhone", "imageData", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Clinic appointments"
    },
    "/medicines/{medicineId}": {
      "schema": "Medicine",
      "description": "Pharmacy inventory"
    },
    "/prescriptions/{prescriptionId}": {
      "schema": "Prescription",
      "description": "Patient prescriptions"
    }
  }
}
